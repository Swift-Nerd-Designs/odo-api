# ── Environment ───────────────────────────────────────────────────
.env
*.env.local
*.env.dev
*.env.prod
*.env.production
.user.ini 

# ── Dependencies ──────────────────────────────────────────────────
/vendor/

# ── CI4 writable (cache, logs, sessions) ─────────────────────────
/writable/cache/*
/writable/logs/*
/writable/session/*
/writable/debugbar/*
!/writable/cache/.gitkeep
!/writable/logs/.gitkeep
!/writable/session/.gitkeep

# ── Uploaded files ────────────────────────────────────────────────
/public/uploads/
!/public/uploads/.gitkeep

# ── Frontend build artifacts (not part of this API) ───────────────
/public/index.html
/public/assets/

# ── OS / editor ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── PHPUnit ───────────────────────────────────────────────────────
.phpunit.result.cache
/build/
